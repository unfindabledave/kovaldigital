# File path to the SQLite file (sql.js, no native bindings). On Vercel, omit or set
# to /tmp/...; the default is /tmp/kovaldigital.sqlite (ephemeral between deploys / cold starts).
DATABASE_URL=./data/kovaldigital.sqlite
NEXT_PUBLIC_SITE_URL=https://kovaldigital.vercel.app
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
